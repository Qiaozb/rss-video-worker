MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD="请填写数据库密码"
MYSQL_DATABASE=dify_test

APP_SECRET_KEY="请生成并固定一个长随机字符串，云端部署必须配置"
ADMIN_USERNAME=admin
# 本地开发留空则不启用登录；云端部署必须设置强密码。
ADMIN_PASSWORD=""
ADMIN_SESSION_HOURS=12
# 只有 HTTPS 访问时才设置为 true。
ADMIN_COOKIE_SECURE=false

TTS_BASE_URL=http://127.0.0.1:9880
TTS_VOICE=Serena

LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY="请填写模型 API Key"
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=180
LLM_TEMPERATURE=0.2

# 通常无需设置。程序会自动使用项目内的 output 和 remotion 目录。
# OUTPUT_DIR=/absolute/path/to/video-worker/output
# REMOTION_ROOT=/absolute/path/to/video-worker/remotion
# REMOTION_PUBLIC_DIR=/absolute/path/to/video-worker/remotion/public
# REMOTION_BROWSER_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30
REMOTION_CONCURRENCY=8
REMOTION_HARDWARE_ACCELERATION=if-possible

# 单次 Remotion 渲染的墙上时钟超时（秒），超时强杀子进程组，避免队列被卡死。
RENDER_TIMEOUT_SECONDS=1800
# 心跳超时阈值（秒）：rendering/running 超过该阈值未刷新心跳的任务被调度器回收。
VIDEO_STALE_SECONDS=900
PIPELINE_STALE_SECONDS=900
# 维护清理：DB 日志保留天数（0 表示不清理）。
AUDIT_LOG_RETENTION_DAYS=90
LLM_CALL_LOG_RETENTION_DAYS=60
